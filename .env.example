# Token do bot Telegram (obtenha no @BotFather)
TELEGRAM_BOT_TOKEN=

# URL de conexão PostgreSQL.
# Localmente pode usar um banco local, mas na Discloud é OBRIGATÓRIO usar
# um banco externo (Neon, Supabase, Railway, Render, Aiven, etc.), pois a
# Discloud não fornece PostgreSQL.
DATABASE_URL=postgresql://user:password@localhost:5432/lojaroupasbot

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Ambiente (development / production).
# Ao configurar as variáveis de ambiente na Discloud, use NODE_ENV=production.
NODE_ENV=development
